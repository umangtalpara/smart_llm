PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/proxyllm
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_should_be_long_and_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
