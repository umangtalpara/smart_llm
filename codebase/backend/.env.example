PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/proxyllm
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_should_be_long_and_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENCRYPTION_KEY=32_bytes_super_secret_aes_key_here

# Mail Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="SmartLLM Support <your-email@gmail.com>"
FRONTEND_URL=http://localhost:3000

# Datadog Integration (Optional)
DD_API_KEY=your_datadog_api_key_here
DD_SITE=us5.datadoghq.com
DD_SERVICE=smart-llm-backend
DD_ENV=development
DD_VERSION=1.0.0
DD_LOGS_ENABLED=true

